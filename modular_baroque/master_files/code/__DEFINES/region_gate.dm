/// Region gate query succeeded and returned a country code.
#define REGION_GATE_QUERY_SUCCESS "success"
/// Region gate query failed due to an internal or network error.
#define REGION_GATE_QUERY_ERROR "error"
/// Region gate query was served from cache.
#define REGION_GATE_QUERY_CACHED "cached"
/// Region gate could not query because the rate limit was exceeded.
#define REGION_GATE_QUERY_RATE_LIMITED "rate_limited"